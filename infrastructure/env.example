# =============================================================================
# PH Agent Hub — Environment Configuration
# =============================================================================
# Copy this file to `env` and fill in your values:
#   cp env.example env
# =============================================================================

# --- Database (MariaDB) ---
DATABASE_URL=mysql+aiomysql://phagent:phagent_password@mariadb:3306/phagent_hub?charset=utf8mb4

# MariaDB credentials (used by Docker Compose and phpMyAdmin)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=phagent
MYSQL_PASSWORD=phagent_password

# --- Cache (Redis) ---
REDIS_URL=redis://redis:6379/0

# --- Object Storage (MinIO) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_PREFIX=phhub-tenant
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- File Upload Limits ---
UPLOAD_MAX_SIZE_BYTES=20971520

# --- Authentication (JWT) ---
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# --- Security ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
COOKIE_SECURE=false
LOGIN_RATE_LIMIT=5/minute
SEED_ALLOW_WEAK_PASSWORD=true

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Frontend ---
VITE_API_URL=/api

# --- Production Domains (Traefik routing via docker-compose.prod.yml) ---
API_DOMAIN=api.phagent.example.com
APP_DOMAIN=app.phagent.example.com
PMA_DOMAIN=pma.phagent.example.com

# --- Docker Images (optional, for docker-compose.prod.yml) ---
# Override these to use a custom registry or tag.
# Defaults: phalouvas/ph-agent-hub-backend:latest and phalouvas/ph-agent-hub-frontend:latest
# BACKEND_IMAGE=ghcr.io/phalouvas/ph-agent-hub-backend
# FRONTEND_IMAGE=ghcr.io/phalouvas/ph-agent-hub-frontend
# IMAGE_TAG=v1.2.3

# --- phpMyAdmin Basic Auth (production only) ---
# Generate with: htpasswd -nb <username> <password>
# Escape every $ as $$ when setting the value in an env file.
# Example: admin:$$apr1$$xyz$$...
PMA_HTPASSWD_USER=

# --- Seed / First Run ---
# Used by scripts/seed.py to create the initial admin user and tenant.
# IMPORTANT: Change ADMIN_PASSWORD before production deployment!
# SEED_ALLOW_WEAK_PASSWORD=true allows the default 'admin' password (dev only).
ADMIN_EMAIL=admin@phagent.local
ADMIN_PASSWORD=admin
DEFAULT_TENANT_NAME=Default
