# =============================================================================
# PH Agent Hub — Environment Configuration
# =============================================================================
# Copy this file to `env` and fill in your values:
#   cp env.example env
# =============================================================================

# --- Database (MariaDB) ---
DATABASE_URL=mysql+aiomysql://phagent:phagent_password@mariadb:3306/phagent_hub?charset=utf8mb4

# MariaDB credentials (used by Docker Compose and phpMyAdmin)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=phagent
MYSQL_PASSWORD=phagent_password

# --- Cache (Redis) ---
REDIS_URL=redis://redis:6379/0

# --- Object Storage (MinIO) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_PREFIX=phagent

# --- File Upload Limits ---
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,application/pdf

# --- Authentication (JWT) ---
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- AI Provider API Keys ---
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Frontend ---
VITE_API_URL=/api

# --- Production Domains (Traefik routing via docker-compose.prod.yml) ---
API_DOMAIN=api.phagent.example.com
APP_DOMAIN=app.phagent.example.com
PMA_DOMAIN=pma.phagent.example.com
